package com.dsc.spos.model;

/**
 * 3.0 apiUser 实体类，用于获取渠道等信息。 接口进来时查一次即可， 不必在每个服务里再查一遍
 * @author yyy 2020-09-14
 *
 */
public class ApiUser {

	private String userCode;
	private String userName;
	private String userKey;
	private String companyId;
	private String shopId;
	private String channelId;
	private String departId;
	private String msgChannelId;
	private String appType;
	private String useDate;//启用有效期管理
	private String endDate;//截止日期
	private String useWhite;//是否启用IP白名单管理
	private String remark;
	
	public String getUserCode() {
		return userCode;
	}
	public String getUserName() {
		return userName;
	}
	public String getUserKey() {
		return userKey;
	}
	public String getCompanyId() {
		return companyId;
	}
	public String getShopId() {
		return shopId;
	}
	public String getChannelId() {
		return channelId;
	}
	public String getDepartId() {
		return departId;
	}
	public String getAppType() {
		return appType;
	}
	public String getUseDate() {
		return useDate;
	}
	public String getEndDate() {
		return endDate;
	}
	public String getUseWhite() {
		return useWhite;
	}
	public String getRemark() {
		return remark;
	}
	public void setUserCode(String userCode) {
		this.userCode = userCode;
	}
	public void setUserName(String userName) {
		this.userName = userName;
	}
	public void setUserKey(String userKey) {
		this.userKey = userKey;
	}
	public void setCompanyId(String companyId) {
		this.companyId = companyId;
	}
	public void setShopId(String shopId) {
		this.shopId = shopId;
	}
	public void setChannelId(String channelId) {
		this.channelId = channelId;
	}
	public void setDepartId(String departId) {
		this.departId = departId;
	}
	public void setAppType(String appType) {
		this.appType = appType;
	}
	public void setUseDate(String useDate) {
		this.useDate = useDate;
	}
	public void setEndDate(String endDate) {
		this.endDate = endDate;
	}
	public void setUseWhite(String useWhite) {
		this.useWhite = useWhite;
	}
	public void setRemark(String remark) {
		this.remark = remark;
	}
	public String getMsgChannelId() {
		return msgChannelId;
	}
	public void setMsgChannelId(String msgChannelId) {
		this.msgChannelId = msgChannelId;
	}
	
}
