package com.dsc.spos.json.cust.res;

import java.util.List;
import com.dsc.spos.json.cust.JsonRes;

/**
 * 服务函数：InvoiceGetDCP
 * 服务说明：发票簿查询
 * @author jinzma 
 * @since  2019-03-1
 */
public class DCP_InvoiceQueryRes  extends JsonRes   {

	private List<level1Elm> datas;
	public List<level1Elm> getDatas() {
		return datas;
	}
	public void setDatas(List<level1Elm> datas) {
		this.datas = datas;
	}

	public class level1Elm{
		private String sellerGuiNo;
		private String year;
		private String startMonth;
		private String endMonth;
		private String invStartNo;
		private String invEndNo;
		private String invType;
		private String invshopNo;
		private String invshopName;
		private String invMachineNo;
		private String isUsed;
		private String invCount;
		private String invLastNo;
		private String invRecipient;
		private String invLoad;
		private String status;

		public String getSellerGuiNo() {
			return sellerGuiNo;
		}
		public void setSellerGuiNo(String sellerGuiNo) {
			this.sellerGuiNo = sellerGuiNo;
		}
		public String getInvStartNo() {
			return invStartNo;
		}
		public void setInvStartNo(String invStartNo) {
			this.invStartNo = invStartNo;
		}
		public String getInvshopNo() {
			return invshopNo;
		}
		public void setInvshopNo(String invshopNo) {
			this.invshopNo = invshopNo;
		}
		public String getInvMachineNo() {
			return invMachineNo;
		}
		public void setInvMachineNo(String invMachineNo) {
			this.invMachineNo = invMachineNo;
		}
		public String getInvLastNo() {
			return invLastNo;
		}
		public void setInvLastNo(String invLastNo) {
			this.invLastNo = invLastNo;
		}
		public String getYear() {
			return year;
		}
		public void setYear(String year) {
			this.year = year;
		}
		public String getStartMonth() {
			return startMonth;
		}
		public void setStartMonth(String startMonth) {
			this.startMonth = startMonth;
		}
		public String getEndMonth() {
			return endMonth;
		}
		public void setEndMonth(String endMonth) {
			this.endMonth = endMonth;
		}
		public String getInvEndNo() {
			return invEndNo;
		}
		public void setInvEndNo(String invEndNo) {
			this.invEndNo = invEndNo;
		}
		public String getInvType() {
			return invType;
		}
		public void setInvType(String invType) {
			this.invType = invType;
		}
		public String getInvshopName() {
			return invshopName;
		}
		public void setInvshopName(String invshopName) {
			this.invshopName = invshopName;
		}
		public String getIsUsed() {
			return isUsed;
		}
		public void setIsUsed(String isUsed) {
			this.isUsed = isUsed;
		}
		public String getInvCount() {
			return invCount;
		}
		public void setInvCount(String invCount) {
			this.invCount = invCount;
		}
		public String getInvRecipient() {
			return invRecipient;
		}
		public void setInvRecipient(String invRecipient) {
			this.invRecipient = invRecipient;
		}
		public String getInvLoad() {
			return invLoad;
		}
		public void setInvLoad(String invLoad) {
			this.invLoad = invLoad;
		}
		public String getStatus() {
			return status;
		}
		public void setStatus(String status) {
			this.status = status;
		}

	}

}
