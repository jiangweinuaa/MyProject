		private String shopId;
		private String shopName;
		private String x;
		private String y;
		private String high;
		private String width;
		private String bgColor;
		private String fntName;
		private String fntSize;
		private String fntColor;
		private String fntStyle;
		private String buttonName;
		private List<level2Elm> datas;
		public String getPageMenuID() {
			return pageMenuID;
		}
		public void setPageMenuID(String pageMenuID) {
			this.pageMenuID = pageMenuID;
		}
		public String getPageID() {
