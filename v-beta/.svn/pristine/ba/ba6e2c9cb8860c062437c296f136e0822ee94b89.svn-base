package com.dsc.spos.hll.api.response;

/**
 * 账单菜品信息
 * @author LN 08546
 */
public class HllFoodDetail {
	
	/**
	 * 操作批次号
	 */
	private String actionBatchNo;
	
	/**
	 * 记录修改时间(改价、赠菜时间）【yyyyMMddHHmmss，默认值0】
	 */
	private String actionTime;
	
	/**
	 * 单注
	 */
	private String allFoodRemark;
	
	/**
	 * 区域名称
	 */
	private String areaName;
	
	/**
	 * 品牌ID
	 */
	private String brandID;
	
	/**
	 * 退菜操作人员empCode|empName
	 */
	private String cancelBy;
	
	/**
	 * 退菜原因
	 */
	private String cancelReason;
	
	/**
	 * 退菜时间【yyyyMMddHHmmss，默认值0】
	 */
	private String cancelTime;
	
	/**
	 * 分类折扣率（当执行分类折扣方案时，此值表示此菜品在分类折扣中的折扣率）
	 */
	private String categoryDiscountRate;
	
	/**
	 * 客户端类型
	 */
	private String clientType;
	
	/**
	 * 记录创建时间（点菜时间、退菜时间）
	 */
