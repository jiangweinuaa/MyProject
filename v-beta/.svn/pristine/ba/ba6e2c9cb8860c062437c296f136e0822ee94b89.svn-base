	/**
	 * 出品部门Key列表，多个间用逗号隔开
	 */
	private String departmentKeyLst;
	
	/**
	 * 第一出品部门
	 */
	private String departmentKeyOne;
	
	/**
	 * 点菜设备名称
	 */
	private String deviceName;
	
	/**
	 * 退菜数量
	 */
	private String foodCancelNumber;
		
	/**
	 * 分类编号，对应基本档-获取店铺菜品返回的foodCategoryKey
	 */
	private String foodCategoryKey;
	
	/**
	 * 分类名称，对应基本档-获取店铺菜品返回的foodCategoryName
	 */
	private String foodCategoryName;
	
	/**
	 * 分类排序值
	 */
	private String foodCategorySortIndex;
	
	/**
	 * 菜品编码，对应基本档-获取店铺菜品返回的foodCode
	 */
	private String foodCode;
	
	/**
	 * 单菜品折扣信息
	 */
	private String foodDiscountRate;
	
	/**
	 * 菜品预估成本
	 */
	private String foodEstimateCost;
	
	/**
	 * 菜品Key，对应基本档-获取店铺菜品返回的foodKey
	 */
	private String foodKey;
	
	/**
	 * 最后一次退菜数量
	 */
	private String foodLastCancelNumber;
	
	/**
	 * 菜品名称，对应基本档-获取店铺菜品返回的foodName
	 */
	private String foodName;
	
	/**
	 * 点菜数量
	 */
	private String foodNumber;
	
	/**
	 * 菜品实收价格，根据折扣科目均摊计算之后的结果
	 */
	private String foodPayPrice;
	
	/**
	 * 菜品成交价，优惠类别按照此价格为计数进行
	 */
	private String foodPayPriceReal;
	
	/**
	 * 菜品做法
	 */
	private String foodPractice;
	
	/**
	 * 菜品折前金额(套餐名字的折前金额为0，套餐明细摊后的折前金额=套餐折前总金额*（套餐明细单点金额/套餐明细单点折前金额合计）)
	 */
	private String foodPriceAmount;
	
	/**
	 * 菜品特价时段特殊价格、区域特殊价格等等
	 */
	private String foodProPrice;
	
	/**
	 * 菜品除去优惠后均摊实收金额
	 */
	private String foodRealAmount;
	
	/**
	 * 菜品的实收价格(除去均摊后的菜品单价)
	 */
	private String foodRealPrice;
	
	/**
	 * 点菜要求
	 */
