package com.dsc.spos.dao;

import java.util.Map;

public class ProcedureBean {

	private String procedure;
	private Map<Integer,Object> inputParameter;
	
	public ProcedureBean(String procedure,Map<Integer,Object> inputParameter )
  {
		this.procedure = procedure;
		this.inputParameter = inputParameter ;  
  }
	
	
  public String getProcedure() {
		return procedure;
	}

	public void setProcedure(String procedure) {
		this.procedure = procedure;
	}

	public Map<Integer, Object> getInputParameter() {
		return inputParameter;
	}

	public void setInputParameter(Map<Integer, Object> inputParameter) {
		this.inputParameter = inputParameter;
	}

	
	
	
}
