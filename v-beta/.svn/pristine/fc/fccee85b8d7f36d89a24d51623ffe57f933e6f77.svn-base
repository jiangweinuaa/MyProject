package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

public class DCP_PGoodsClassUpdateReq extends JsonBasicReq 
{
	private levelElm request;
	public levelElm getRequest() {
		return request;
	}
	public void setRequest(levelElm request) {
		this.request = request;
	}
	public class levelElm{
		private String pclassNo;
		private String pclassName;
		private String status;

		public String getPclassNo() {
			return pclassNo;
		}
		public void setPclassNo(String pclassNo) {
			this.pclassNo = pclassNo;
		}
		public String getPclassName() {
			return pclassName;
		}
		public void setPclassName(String pclassName) {
			this.pclassName = pclassName;
		}
		public String getStatus() {
			return status;
		}
		public void setStatus(String status) {
			this.status = status;
		}
	}

}
