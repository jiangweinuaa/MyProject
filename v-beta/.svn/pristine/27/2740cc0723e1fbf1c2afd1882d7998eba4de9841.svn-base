package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 服務函數：BarcodeInforGet
 *    說明：商品查询
 * 服务说明：商品查询
 * @author panjing 
 * @since  2016-09-22
 */
public class DCP_OrderBarcodeInforQueryReq extends JsonBasicReq {

	/**JSON Request
	 * 
		"serviceId": "GoodsCheck",	必傳，服務名
		"token": "f14ee75ff5b220177ac0dc538bdea08c",	必傳，訪問令牌
		"pluBarcode": ["01","02"],	必傳，商品条码		
	 * 
	 **/
	private String keyTxt;

	private String[] pluBarcode;

	private String oShopId;

	public String[] getPluBarcode() {
		return pluBarcode;
	}
	public void setPluBarcode(String[] pluBarcode) {
		this.pluBarcode = pluBarcode;
	}
	public String getoShopId() {
		return oShopId;
	}
	public void setoShopId(String oShopId) {
		this.oShopId = oShopId;
	}
	public String getKeyTxt() {
		return keyTxt;
	}
	public void setKeyTxt(String keyTxt) {
		this.keyTxt = keyTxt;
	}



}
