package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;
/**
 * 服務函數：ProcessTaskProcess
 *    說明：加工任务单执行
 * 服务说明：加工任务单执行
 * @author luoln 
 * @since  2017-03-31
 */
public class DCP_ProcessTaskProcessReq extends JsonBasicReq {

	private levelElm request;	
	public levelElm getRequest() {
		return request;
	}
	public void setRequest(levelElm request) {
		this.request = request;
	}

	public class levelElm{
		private String processTaskNo;
        private String status;
		public String getProcessTaskNo() {
			return processTaskNo;
		}
		public void setProcessTaskNo(String processTaskNo) {
			this.processTaskNo = processTaskNo;
		}

        public String getStatus() {
            return status;
        }

        public void setStatus(String status) {
            this.status = status;
        }
    }

}
