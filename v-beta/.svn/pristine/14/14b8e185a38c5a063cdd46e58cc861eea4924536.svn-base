import com.dsc.spos.json.cust.JsonRes;

/**
 * 电商订单导出格式查询
 * @author yuanyy 2019-03-13
 *
 */
public class DCP_OrderECExpFormatQueryRes extends JsonRes {
	private List<level1Elm> datas;

	public class level1Elm{
		private String expOrderFormatNo;
		private String expOrderFormatName;
		private String ecplatformNo;
		private String ecplatformName;
		private String pickupWay;
		private String exportType;
		private String ftp_uid;
		private String ftp_pwd;
		private String filePath;
		private String memo;
		private String status;

		private List<level2Elm> datas;
		public String getExpOrderFormatNo() {
			return expOrderFormatNo;
		}
		public void setExpOrderFormatNo(String expOrderFormatNo) {
			this.expOrderFormatNo = expOrderFormatNo;
		}
		public String getExpOrderFormatName() {
			return expOrderFormatName;
		}
		public void setExpOrderFormatName(String expOrderFormatName) {
			this.expOrderFormatName = expOrderFormatName;
		}
		public String getEcplatformNo() {
			return ecplatformNo;
		}
		public void setEcplatformNo(String ecplatformNo) {
			this.ecplatformNo = ecplatformNo;
		}
		public String getEcplatformName() {
			return ecplatformName;
		}
		public void setEcplatformName(String ecplatformName) {
			this.ecplatformName = ecplatformName;
		}
		public String getPickupWay() {
			return pickupWay;
		}
		public void setPickupWay(String pickupWay) {
			this.pickupWay = pickupWay;
		}
		public String getExportType() {
			return exportType;
		}
		public void setExportType(String exportType) {
			this.exportType = exportType;
		}
		public String getFtp_uid() {
			return ftp_uid;
		}
		public void setFtp_uid(String ftp_uid) {
			this.ftp_uid = ftp_uid;
		}
		public String getFtp_pwd() {
			return ftp_pwd;
		}
		public void setFtp_pwd(String ftp_pwd) {
			this.ftp_pwd = ftp_pwd;
		}
		public String getFilePath() {
			return filePath;
		}
		public void setFilePath(String filePath) {
			this.filePath = filePath;
		}
		public String getMemo() {
			return memo;
		}
		public void setMemo(String memo) {
			this.memo = memo;
		}
		public String getStatus() {
			return status;
		}
		public void setStatus(String status) {
			this.status = status;
		}
		public List<level2Elm> getDatas() {
			return datas;
		}
		public void setDatas(List<level2Elm> datas) {
			this.datas = datas;
		}

	}

	public class level2Elm{
		private String item;
		private String excelColumnNo;
		private String excelColumnTitle;
		private String dataType;
		private String tableName;
		private String fieldName;
		private String fieldMemo;
		private String fixValue;
		private String status;
		public String getItem() {
			return item;
		}
		public void setItem(String item) {
			this.item = item;
		}
		public String getExcelColumnNo() {
			return excelColumnNo;
		}
		public void setExcelColumnNo(String excelColumnNo) {
