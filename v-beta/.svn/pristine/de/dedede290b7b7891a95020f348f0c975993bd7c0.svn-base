package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 服务函数：DCP_SubStockTakeCreate
 * 服务说明：盘点子任务新增
 * @author jinzma
 * @since  2021-02-24
 */
public class DCP_SubStockTakeCreateReq extends JsonBasicReq {
    private levelElm request;

    public levelElm getRequest() {
        return request;
    }
    public void setRequest(levelElm request) {
        this.request = request;
    }

    public class levelElm{
        private String bDate;
        private String stockTakeNo;
        private String deviceNo;
        private String stockType;
        private String subStockTakeId;
        private String memo;

        public String getbDate() {
            return bDate;
        }
        public void setbDate(String bDate) {
            this.bDate = bDate;
        }
        public String getStockTakeNo() {
            return stockTakeNo;
        }
        public void setStockTakeNo(String stockTakeNo) {
            this.stockTakeNo = stockTakeNo;
        }
        public String getDeviceNo() {
            return deviceNo;
        }
        public void setDeviceNo(String deviceNo) {
            this.deviceNo = deviceNo;
        }
        public String getStockType() {
            return stockType;
        }
        public void setStockType(String stockType) {
            this.stockType = stockType;
        }
        public String getSubStockTakeId() {
            return subStockTakeId;
        }
        public void setSubStockTakeId(String subStockTakeId) {
            this.subStockTakeId = subStockTakeId;
        }
        public String getMemo() {
            return memo;
        }
        public void setMemo(String memo) {
            this.memo = memo;
        }
    }
}
