package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

public class DCP_OrderPlatformGoodsBatchMappingReq extends JsonBasicReq {
	private String loadDocType;
	private String[] erpShopNO;
	private String isEmptyPluNO;//是否为空的，美团聚宝盆，
	public String getLoadDocType() {
		return loadDocType;
	}
	public void setLoadDocType(String loadDocType) {
		this.loadDocType = loadDocType;
	}
	public String[] getErpShopNO() {
		return erpShopNO;
	}
	public void setErpShopNO(String[] erpShopNO) {
		this.erpShopNO = erpShopNO;
	}
	public String getIsEmptyPluNO() {
		return isEmptyPluNO;
	}
	public void setIsEmptyPluNO(String isEmptyPluNO) {
		this.isEmptyPluNO = isEmptyPluNO;
	}
	
	

}
