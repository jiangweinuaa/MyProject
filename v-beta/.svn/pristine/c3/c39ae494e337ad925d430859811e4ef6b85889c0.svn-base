package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

public class DCP_OrderECGreenworldMapQueryReq extends JsonBasicReq
{	
	//1：全家  2:萊爾富 3：7-ELEVEN ，必传
	private String shopType;
	
	//是否代收货款 Y/N ,默认N
	private String canCollection;
	
	//后台服务地址，为空取数据库
	private String serverReplyUrl;
	
	//约定资料,由 订单号@@@企业编码@@@门店编号@@@时间戳  组成，必传
	private String extraData;
	
	//使用设备 0：PC 1：Mobile ，默认0
	private String device;
	


	public String getShopType() {
		return shopType;
	}

	public void setShopType(String shopType) {
		this.shopType = shopType;
	}

	public String getCanCollection() {
		return canCollection;
	}

	public void setCanCollection(String canCollection) {
		this.canCollection = canCollection;
	}

	public String getServerReplyUrl() {
		return serverReplyUrl;
	}

	public void setServerReplyUrl(String serverReplyUrl) {
		this.serverReplyUrl = serverReplyUrl;
	}

	public String getExtraData() {
		return extraData;
	}

	public void setExtraData(String extraData) {
		this.extraData = extraData;
	}

	public String getDevice() {
		return device;
	}

	public void setDevice(String device) {
		this.device = device;
	}
	
	
	
	
	
}
