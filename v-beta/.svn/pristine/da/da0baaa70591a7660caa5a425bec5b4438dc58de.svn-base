package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 生产计划预估修改
 * @author yuanyy 
 *
 */
public class DCP_PlanDetailUpdateReq extends JsonBasicReq {
	
	private String planNo;
	private String bDate;
	
	private String beginTime; // 时间段开始时间和结束时间
	private String endTime;
	
	private String fType;
	private String fNo;
	private String avgAmt;
	private String predictAmt;
	
	private String predictAmtOld;
	
	private String status;
	
	
	public String getPlanNo() {
		return planNo;
	}
	public void setPlanNo(String planNo) {
		this.planNo = planNo;
	}
	public String getBeginTime() {
		return beginTime;
	}
	public void setBeginTime(String beginTime) {
		this.beginTime = beginTime;
	}
	public String getEndTime() {
		return endTime;
	}
	public void setEndTime(String endTime) {
		this.endTime = endTime;
	}
	public String getbDate() {
		return bDate;
	}
	public void setbDate(String bDate) {
		this.bDate = bDate;
	}
	public String getfType() {
		return fType;
	}
	public void setfType(String fType) {
		this.fType = fType;
	}
	public String getfNo() {
		return fNo;
	}
	public void setfNo(String fNo) {
		this.fNo = fNo;
	}
	public String getAvgAmt() {
		return avgAmt;
	}
	public void setAvgAmt(String avgAmt) {
		this.avgAmt = avgAmt;
	}
	public String getPredictAmt() {
		return predictAmt;
	}
	public void setPredictAmt(String predictAmt) {
		this.predictAmt = predictAmt;
	}
	public String getPredictAmtOld() {
		return predictAmtOld;
	}
	public void setPredictAmtOld(String predictAmtOld) {
		this.predictAmtOld = predictAmtOld;
	}
	public String getStatus() {
		return status;
	}
	public void setStatus(String status) {
		this.status = status;
	}
	
}
