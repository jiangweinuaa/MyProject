package com.dsc.spos.waimai.jddj;

import java.util.List;

public class OQueryStockResponseResult {

   private String isRet;
   private String retCode;
   private String retMsg;
   private List<OQueryStockResponse> data;
   public void setIsRet(String isRet) {
        this.isRet = isRet;
    }
    public String getIsRet() {
        return isRet;
    }

   public void setRetCode(String retCode) {
        this.retCode = retCode;
    }
    public String getRetCode() {
        return retCode;
    }

   public void setRetMsg(String retMsg) {
        this.retMsg = retMsg;
    }
    public String getRetMsg() {
        return retMsg;
    }

   public void setData(List<OQueryStockResponse> data) {
        this.data = data;
    }
    public List<OQueryStockResponse> getData() {
        return data;
    }

}