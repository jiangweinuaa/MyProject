package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

public class DCP_PGoodsClassCreateReq extends JsonBasicReq
{
	private levelRequest request;

	public levelRequest getRequest() {
		return request;
	}

	public void setRequest(levelRequest request) {
		this.request = request;
	}

	public class levelRequest
	{
		private String pclassNo;
		private String pclassName;

		public String getPclassNo() {
			return pclassNo;
		}
		public void setPclassNo(String pclassNo) {
			this.pclassNo = pclassNo;
		}
		public String getPclassName() {
			return pclassName;
		}
		public void setPclassName(String pclassName) {
			this.pclassName = pclassName;
		}


	}




}
