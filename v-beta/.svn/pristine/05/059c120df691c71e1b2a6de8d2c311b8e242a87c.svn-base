package com.dsc.spos.waimai.jddj;

import java.util.List;

public class OUpdateVendibilityResult {

   private String retCode;
   private String retMsg;
   private boolean ret;
   private List<OUpdateVendibilityResponse> data;
   public void setRetCode(String retCode) {
        this.retCode = retCode;
    }
    public String getRetCode() {
        return retCode;
    }

   public void setRetMsg(String retMsg) {
        this.retMsg = retMsg;
    }
    public String getRetMsg() {
        return retMsg;
    }

   public void setRet(boolean ret) {
        this.ret = ret;
    }
    public boolean getRet() {
        return ret;
    }

   public void setData(List<OUpdateVendibilityResponse> data) {
        this.data = data;
    }
    public List<OUpdateVendibilityResponse> getData() {
        return data;
    }

}