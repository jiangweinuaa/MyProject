package com.dsc.spos.json.cust.res;

import com.dsc.spos.json.cust.JsonRes;

import java.util.List;

public class DCP_SaleOrderQuery_OpenRes extends JsonRes {
	
	private List<Level1Elm> datas;
	
	public List<Level1Elm> getDatas() {
		return datas;
	}

	public void setDatas(List<Level1Elm> datas) {
		this.datas = datas;
	}

	public  class Level1Elm {
		
		private String saleNo;//销售单号
		
		private String memo;//销售单备注
		
		private String machine;//机台号
		
		private String bdate;//营业时间
		
		private String cardNo;//会员卡号
		
		private String memberId;//会员id
		
		private String mobilePhone;//会员手机号
		
		private String tot_qty;//总数量
		
		private String amt;//成交金额，对应表中：TD_SALE.TOT_AMT
		
		private String tot_oldAmt;//订单金额，对应表：TD_SALE.TOT_OLDAMT
		
		private String tot_changed;//找零金额
		
		private String sdate;//订转销日期
		
		private String stime;//定转销时间
		
		private String shopNo;//下单门店编码
		
		private String crateTime;//订单创建开始时间
		
		private String o_saleNo;//原销售单
		
		private String amtDiscount;//折扣总额TOT_DISC
		
		private String type;//单据类型 0销售单，1销退单
		
		private List<Good> goodList;//商品列表
		
		private List<Pay> payList;//
		
		private String shipType;//1.订单来源渠道配送 2.全国快递 3.顾客自提 5ERP总部配送 6同城配送
		

		public String getShipType() {
			return shipType;
		}

		public void setShipType(String shipType) {
			this.shipType = shipType;
		}

		public String getSaleNo() {
			return saleNo;
		}

		public void setSaleNo(String saleNo) {
			this.saleNo = saleNo;
		}

		public String getMemo() {
			return memo;
		}

		public void setMemo(String memo) {
			this.memo = memo;
		}

		public String getMachine() {
			return machine;
		}

		public void setMachine(String machine) {
			this.machine = machine;
		}

		public String getBdate() {
			return bdate;
		}

		public void setBdate(String bdate) {
			this.bdate = bdate;
		}

		public String getCardNo() {
			return cardNo;
		}

		public void setCardNo(String cardNo) {
			this.cardNo = cardNo;
		}

		public String getMemberId() {
			return memberId;
		}

		public void setMemberId(String memberId) {
			this.memberId = memberId;
		}

		public String getMobilePhone() {
			return mobilePhone;
		}

		public void setMobilePhone(String mobilePhone) {
			this.mobilePhone = mobilePhone;
		}

		public String getTot_qty() {
			return tot_qty;
		}

		public void setTot_qty(String tot_qty) {
			this.tot_qty = tot_qty;
		}

		public String getAmt() {
			return amt;
		}

		public void setAmt(String amt) {
			this.amt = amt;
		}

		public String getTot_oldAmt() {
			return tot_oldAmt;
		}

		public void setTot_oldAmt(String tot_oldAmt) {
			this.tot_oldAmt = tot_oldAmt;
		}

		public String getTot_changed() {
			return tot_changed;
		}

		public void setTot_changed(String tot_changed) {
			this.tot_changed = tot_changed;
		}

		public String getSdate() {
			return sdate;
		}

		public void setSdate(String sdate) {
			this.sdate = sdate;
		}

		public String getStime() {
			return stime;
		}

		public void setStime(String stime) {
			this.stime = stime;
		}

		public String getShopNo() {
			return shopNo;
		}

		public void setShopNo(String shopNo) {
			this.shopNo = shopNo;
		}

		public String getCrateTime() {
			return crateTime;
		}

		public void setCrateTime(String crateTime) {
			this.crateTime = crateTime;
		}

		public String getO_saleNo() {
			return o_saleNo;
		}

		public void setO_saleNo(String o_saleNo) {
			this.o_saleNo = o_saleNo;
		}

		public String getAmtDiscount() {
			return amtDiscount;
		}

		public void setAmtDiscount(String amtDiscount) {
			this.amtDiscount = amtDiscount;
		}

		public String getType() {
			return type;
		}

		public void setType(String type) {
			this.type = type;
		}

		public List<Good> getGoodList() {
			return goodList;
		}

		public void setGoodList(List<Good> goodList) {
			this.goodList = goodList;
		}

		public List<Pay> getPayList() {
			return payList;
		}

		public void setPayList(List<Pay> payList) {
			this.payList = payList;
		}
		
	}
	
	public  class Good {
		
		private String item;//项次
		
		private String pluno;//商品编码
		
		private String pluBarcode;//商品条码
		
		private String pluName;//商品名称TB_GOODS.PLUNAME
		
		private String oldPrice;//原单价
		
		private String price;//售价
		
		private String qty;//数量
		
		private String disc;//折扣金额
		
		private String amt;//成交金额
		
		private String rqty;//退货数量
		
		private String memo;//商品备注
		
		private String isPackage;//是否是套餐商品 Y是，N不是
		
		private String packageMaster;//是否是套餐主商品 Y是，N不是
		
		private String unit;//销售单位
		
		private String packageAmt;//套餐金额
		
		private String packageQty;//套餐数量
		
		private String upItem;//主套餐项次

		public String getItem() {
			return item;
		}

		public void setItem(String item) {
			this.item = item;
		}

		public String getPluno() {
			return pluno;
		}

		public void setPluno(String pluno) {
			this.pluno = pluno;
		}

		public String getPluBarcode() {
			return pluBarcode;
		}

		public void setPluBarcode(String pluBarcode) {
			this.pluBarcode = pluBarcode;
		}

		public String getPluName() {
			return pluName;
		}

		public void setPluName(String pluName) {
			this.pluName = pluName;
		}

		public String getOldPrice() {
			return oldPrice;
		}

		public void setOldPrice(String oldPrice) {
			this.oldPrice = oldPrice;
		}

		public String getPrice() {
			return price;
		}

		public void setPrice(String price) {
			this.price = price;
		}

		public String getQty() {
			return qty;
		}

		public void setQty(String qty) {
			this.qty = qty;
		}

		public String getDisc() {
			return disc;
		}

		public void setDisc(String disc) {
			this.disc = disc;
		}

		public String getAmt() {
			return amt;
		}

		public void setAmt(String amt) {
			this.amt = amt;
		}

		public String getRqty() {
			return rqty;
		}

		public void setRqty(String rqty) {
			this.rqty = rqty;
		}

		public String getMemo() {
			return memo;
		}

		public void setMemo(String memo) {
			this.memo = memo;
		}

		public String getIsPackage() {
			return isPackage;
		}

		public void setIsPackage(String isPackage) {
			this.isPackage = isPackage;
		}

		public String getPackageMaster() {
			return packageMaster;
		}

		public void setPackageMaster(String packageMaster) {
			this.packageMaster = packageMaster;
		}

		public String getUnit() {
			return unit;
		}

		public void setUnit(String unit) {
			this.unit = unit;
		}

		public String getPackageAmt() {
			return packageAmt;
		}

		public void setPackageAmt(String packageAmt) {
			this.packageAmt = packageAmt;
		}

		public String getPackageQty() {
			return packageQty;
		}

		public void setPackageQty(String packageQty) {
			this.packageQty = packageQty;
		}

		public String getUpItem() {
			return upItem;
		}

		public void setUpItem(String upItem) {
			this.upItem = upItem;
		}
		
	}
	
	public  class Pay {
		
		private String item;//项次
		
		private String payCode;//支付方式
		
		private String payName;//支付方式名称
		
		private String cardNo;//券号/卡号
		
		private String payserNum;//支付订单号
		
		private String pay;//支付金额
		
		private String changed;//找零
		
		private String extra;//券溢收金额
		
		private String serialNo;//银行卡流水号
		
		private String refNo;//银行卡参考号
		
		private String teriminalNo;//终端号

		public String getItem() {
			return item;
		}

		public void setItem(String item) {
			this.item = item;
		}

		public String getPayCode() {
			return payCode;
		}

		public void setPayCode(String payCode) {
			this.payCode = payCode;
		}

		public String getPayName() {
			return payName;
		}

		public void setPayName(String payName) {
			this.payName = payName;
		}

		public String getCardNo() {
			return cardNo;
		}

		public void setCardNo(String cardNo) {
			this.cardNo = cardNo;
		}

		public String getPayserNum() {
			return payserNum;
		}

		public void setPayserNum(String payserNum) {
			this.payserNum = payserNum;
		}

		public String getPay() {
			return pay;
		}

		public void setPay(String pay) {
			this.pay = pay;
		}

		public String getChanged() {
			return changed;
		}

		public void setChanged(String changed) {
			this.changed = changed;
		}

		public String getExtra() {
			return extra;
		}

		public void setExtra(String extra) {
			this.extra = extra;
		}

		public String getSerialNo() {
			return serialNo;
		}

		public void setSerialNo(String serialNo) {
			this.serialNo = serialNo;
		}

		public String getRefNo() {
			return refNo;
		}

		public void setRefNo(String refNo) {
			this.refNo = refNo;
		}

		public String getTeriminalNo() {
			return teriminalNo;
		}

		public void setTeriminalNo(String teriminalNo) {
			this.teriminalNo = teriminalNo;
		}
		
	}

}
