package com.dsc.spos.json.cust.req;

import java.util.List;

import com.dsc.spos.json.JsonBasicReq;

public class DCP_FuncButtonCreateReq extends JsonBasicReq {
	private levelElm request;
	public levelElm getRequest() {
		return request;
	}
	public void setRequest(levelElm request) {
		this.request = request;
	}
	public class levelElm{
		private String ptemplateNo; 
		private String ptemplateName;
		private String businessType;
		private List<level1Elm> datas;
		private List<level1shopsElm> shops;

		public String getPtemplateNo() {
			return ptemplateNo;
		}

		public void setPtemplateNo(String ptemplateNo) {
			this.ptemplateNo = ptemplateNo;
		}

		public String getPtemplateName() {
			return ptemplateName;
		}

		public void setPtemplateName(String ptemplateName) {
			this.ptemplateName = ptemplateName;
		}

		public List<level1Elm> getDatas() {
			return datas;
		}

		public void setDatas(List<level1Elm> datas) {
			this.datas = datas;
		}

		public List<level1shopsElm> getShops() {
			return shops;
		}

		public void setShops(List<level1shopsElm> shops) {
			this.shops = shops;
		}

		public String getBusinessType() {
			return businessType;
		}

		public void setBusinessType(String businessType) {
			this.businessType = businessType;
		}
	}
	public class level1Elm {
		private String funcNo;
		private String icon;
		private String funcGroup;
		private String qss;
		private String priority;
		private String approveneed;
		private String status;

		public String getFuncNo() {
			return funcNo;
		}

		public void setFuncNo(String funcNo) {
			this.funcNo = funcNo;
		}

		public String getIcon() {
			return icon;
		}

		public void setIcon(String icon) {
			this.icon = icon;
		}

		public String getFuncGroup() {
			return funcGroup;
		}

		public void setFuncGroup(String funcGroup) {
			this.funcGroup = funcGroup;
		}

		public String getQss() {
			return qss;
		}

		public void setQss(String qss) {
			this.qss = qss;
		}

		public String getPriority() {
			return priority;
		}

		public void setPriority(String priority) {
			this.priority = priority;
		}

		public String getApproveneed() {
			return approveneed;
		}

		public void setApproveneed(String approveneed) {
			this.approveneed = approveneed;
		}

		public String getStatus() {
			return status;
		}

		public void setStatus(String status) {
			this.status = status;
		}


	}

	public class level1shopsElm {

		private String shopId;

		public String getShopId() {
			return shopId;
		}

		public void setShopId(String shopId) {
			this.shopId = shopId;
		}
	}
}
