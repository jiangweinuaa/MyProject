package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 虾皮商店授权	
 * @author 2019-04-02
 *
 */
public class DCP_OrderECShopAuthQueryReq extends JsonBasicReq {
	
    private String authType;
    private String ecPlatformNo;
    private String apiUrl;
    private String xp_PartnerId;
    private String xp_PartnerKey;
    private String redirectUrl;
	public String getAuthType() {
		return authType;
	}
	public void setAuthType(String authType) {
		this.authType = authType;
	}
	public String getEcPlatformNo() {
		return ecPlatformNo;
	}
	public void setEcPlatformNo(String ecPlatformNo) {
		this.ecPlatformNo = ecPlatformNo;
	}
	public String getApiUrl() {
		return apiUrl;
	}
	public void setApiUrl(String apiUrl) {
		this.apiUrl = apiUrl;
	}
	public String getXp_PartnerId() {
		return xp_PartnerId;
	}
	public void setXp_PartnerId(String xp_PartnerId) {
		this.xp_PartnerId = xp_PartnerId;
	}
	public String getXp_PartnerKey() {
		return xp_PartnerKey;
	}
	public void setXp_PartnerKey(String xp_PartnerKey) {
		this.xp_PartnerKey = xp_PartnerKey;
	}
	public String getRedirectUrl() {
		return redirectUrl;
	}
	public void setRedirectUrl(String redirectUrl) {
		this.redirectUrl = redirectUrl;
	}
	
}
