package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;
import com.dsc.spos.json.cust.res.DCP_CurrencyQueryRes;

import java.util.List;

public class DCP_CurrencyAlterReq extends JsonBasicReq {


    private DCP_CurrencyAlterReq.levelRequest request;

    public DCP_CurrencyAlterReq.levelRequest getRequest() {
        return request;
    }

    public void setRequest(DCP_CurrencyAlterReq.levelRequest request) {
        this.request = request;
    }

    public class levelRequest
    {
        private String oprType;
        private String nation;
        private String currency;
        private String minValue;
        private String symbol;
        private String priceDigit;
        private String amountDigit;
        private String costPriceDigit;
        private String costAmountDigit;
        private String status;
        private List<DCP_CurrencyAlterReq.level1Elm> currencyName_lang;




        public String getNation() {
            return nation;
        }

        public void setNation(String nation) {
            this.nation = nation;
        }

        public String getCurrency() {
            return currency;
        }

        public void setCurrency(String currency) {
            this.currency = currency;
        }

        public String getMinValue() {
            return minValue;
        }

        public void setMinValue(String minValue) {
            this.minValue = minValue;
        }

        public String getSymbol() {
            return symbol;
        }

        public void setSymbol(String symbol) {
            this.symbol = symbol;
        }

        public String getPriceDigit() {
            return priceDigit;
        }

        public void setPriceDigit(String priceDigit) {
            this.priceDigit = priceDigit;
        }

        public String getAmountDigit() {
            return amountDigit;
        }

        public void setAmountDigit(String amountDigit) {
            this.amountDigit = amountDigit;
        }

        public String getCostPriceDigit() {
            return costPriceDigit;
        }

        public void setCostPriceDigit(String costPriceDigit) {
            this.costPriceDigit = costPriceDigit;
        }

        public String getCostAmountDigit() {
            return costAmountDigit;
        }

        public void setCostAmountDigit(String costAmountDigit) {
            this.costAmountDigit = costAmountDigit;
        }

        public String getStatus() {
            return status;
        }

        public void setStatus(String status) {
            this.status = status;
        }


        public String getOprType() {
            return oprType;
        }

        public void setOprType(String oprType) {
            this.oprType = oprType;
        }

        public List<level1Elm> getCurrencyName_lang() {
            return currencyName_lang;
        }

        public void setCurrencyName_lang(List<level1Elm> currencyName_lang) {
            this.currencyName_lang = currencyName_lang;
        }
    }

    public class level1Elm {
        private String langType;
        private String name;

        public String getLangType() {
            return langType;
        }

        public void setLangType(String langType) {
            this.langType = langType;
        }

        public String getName() {
            return name;
        }

        public void setName(String name) {
            this.name = name;
        }



    }



}
