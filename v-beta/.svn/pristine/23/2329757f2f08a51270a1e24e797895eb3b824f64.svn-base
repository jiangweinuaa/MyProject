package com.dsc.spos.json.cust.res;

import java.util.List;
import com.dsc.spos.json.JsonBasicRes;


/**
 * EDateGet 專用的 response json
 * @author panjing 
 * @since  2016-09-22
 */

public class DCP_EDateQueryRes extends JsonBasicRes {
	private List<level2Elm> datas;
	

	public List<level2Elm> getDatas() {
		return datas;
	}


	public void setDatas(List<level2Elm> datas) {
		this.datas = datas;
	}


	public class level2Elm{
		
		private String maxEDate;

		public String getMaxEDate() {
			return maxEDate;
		}

		public void setMaxEDate(String maxEDate) {
			this.maxEDate = maxEDate;
		}
		
	} 
	
}