package com.dsc.spos.json.cust.res;

import java.util.List;

import com.dsc.spos.json.cust.JsonRes;
import com.dsc.spos.json.cust.res.DCP_OrderBasicSettingQueryRes.responseDatas;

/**
 * 平台支付方式映射查询
 * @author yuanyy 2019-04-24
 *
 */
public class DCP_MappingPaymentQueryRes extends JsonRes
{

	private responseDatas datas;

	public responseDatas getDatas()
	{
		return datas;
	}

	public void setDatas(responseDatas datas)
	{
		this.datas = datas;
	}

	public class responseDatas
	{
		private List<level1Elm> datas;

		public List<level1Elm> getDatas()
		{
			return datas;
		}

		public void setDatas(List<level1Elm> datas)
		{
			this.datas = datas;
		}
	}

	public class level1Elm
	{
		private String loadDocType;
		private String ERP_payCode;
		private String ERP_payName;
		private String ERP_payType;
		private String order_payCode;
		private String order_payName;
		private String order_payType;
		private String status;

		public String getLoadDocType()
		{
			return loadDocType;
		}

		public void setLoadDocType(String loadDocType)
		{
			this.loadDocType = loadDocType;
		}

		public String getERP_payCode()
		{
			return ERP_payCode;
		}

		public void setERP_payCode(String eRP_payCode)
		{
			ERP_payCode = eRP_payCode;
		}

		public String getERP_payName()
		{
			return ERP_payName;
		}

		public void setERP_payName(String eRP_payName)
		{
			ERP_payName = eRP_payName;
		}

		public String getERP_payType()
		{
			return ERP_payType;
		}

		public void setERP_payType(String eRP_payType)
		{
			ERP_payType = eRP_payType;
		}

		public String getOrder_payCode()
		{
			return order_payCode;
		}

		public void setOrder_payCode(String order_payCode)
		{
			this.order_payCode = order_payCode;
		}

		public String getOrder_payName()
		{
			return order_payName;
		}

		public void setOrder_payName(String order_payName)
		{
			this.order_payName = order_payName;
		}

		public String getOrder_payType()
		{
			return order_payType;
		}

		public void setOrder_payType(String order_payType)
		{
			this.order_payType = order_payType;
		}

		public String getStatus()
		{
			return status;
		}

		public void setStatus(String status)
		{
			this.status = status;
		}

	}

}	
