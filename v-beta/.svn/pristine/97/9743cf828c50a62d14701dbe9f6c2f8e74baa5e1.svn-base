package com.dsc.spos.thirdpart.youzan.request;

/**
 * 交易成功
 * 买家确认收货或系统自动确认收货且主订单状态变为「交易成功」时触发
 * https://doc.youzanyun.com/doc#/content/MSG/20-交易消息/detail/msg/trade_TradeSuccess
 */

public class YouZanNotifyTradeSuccessReq extends YouZanNotifyBasicReq {

	private String tid;//订单号
	private String update_time;//更新时间
	public String getTid() {
		return tid;
	}
	public void setTid(String tid) {
		this.tid = tid;
	}
	public String getUpdate_time() {
		return update_time;
	}
	public void setUpdate_time(String update_time) {
		this.update_time = update_time;
	}

}
