package com.dsc.spos.utils;

public class GoodFeature {

	String _featureName = "";
   String _featureNO = "";
   
   public GoodFeature(String featureNO, String featureName){
       this._featureNO = featureNO;
       this._featureName = featureName;
   }
   
	public String getFeatureName() {
		return this._featureName;
	}

	public String getFeatureNO() {
		return this._featureNO;
	}
   
}
