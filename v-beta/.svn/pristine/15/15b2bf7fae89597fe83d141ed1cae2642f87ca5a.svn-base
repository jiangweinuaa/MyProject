package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;
/**
 * 服务函数：DingUserSetGetDCP
 * 服务说明： 钉钉用户设置查询
 * @author jinzma
 * @since  2019-10-28
 */
public class DCP_DingUserSetQueryReq extends JsonBasicReq {

	private levelElm request;
	public levelElm getRequest() {
		return request;
	}
	public void setRequest(levelElm request) {
		this.request = request;
	}
	public class levelElm{
		private String opGNo ;
		private String staffsShopNo;
		private String isMapping;
		private String keyTxt;
		public String getOpGNo() {
			return opGNo;
		}
		public void setOpGNo(String opGNo) {
			this.opGNo = opGNo;
		}
		public String getStaffsShopNo() {
			return staffsShopNo;
		}
		public void setStaffsShopNo(String staffsShopNo) {
			this.staffsShopNo = staffsShopNo;
		}
		public String getIsMapping() {
			return isMapping;
		}
		public void setIsMapping(String isMapping) {
			this.isMapping = isMapping;
		}
		public String getKeyTxt() {
			return keyTxt;
		}
		public void setKeyTxt(String keyTxt) {
			this.keyTxt = keyTxt;
		}


	}

}
