package com.dsc.spos.waimai;

import java.io.Serializable;
import java.math.BigDecimal;

public class RRKDFastInfoVO implements Serializable
{
	/**
	 * serialVersionUID
	 */
	private static final long serialVersionUID = 7214745598458561513L;
	/**
	 * 人人快递分配的第三方平台账号
	 */
	private String userName;
	/**
	 * 商品名称
	 */
	private String businessNo;
	/**
	 * 商品重量
	 */
	private String goodsName;
	/**
	 * 商品重量  KG
	 */
	private Integer goodsWeight;
	/**
	 * 商品价值 ￥
	 */
	private Integer goodsWorth;
	/**
	 * 地图坐标来源（
	 * 1=baidu，
	 * 2=google/soso/aliyun/mapabc/amap，
	 * 3=51map）
	 */
	private Integer mapFrom;
	/**
	 * 发货人电话
	 */
	private String startingPhone;
	/**
	 * 发货人省份
	 */
	private String startingProvince;
	/**
	 * 发货人城市
	 */
	private String startingCity;
	/**
	 * 发货人详细地址
	 */
	private String startingAddress;
	/**
	 * 发货人地图经度（保留地图所有小数）
	 */
	private BigDecimal startingLng;
	/**
	 * 发货人地图纬度（保留地图所有小数）
	 */
	private BigDecimal startingLat;
	/**
	 * 发货人姓名
	 */
	private String startingName;
	/**
	 * 收货人省份
	 */
	private String consigneeProvince;
	/**
	 * 收货人城市
	 */
	private String consigneeCity;
	/**
	 * 收货人详细地址
	 */
	private String consigneeAddress;
	/**
	 *收货人地图经度（保留地图所有小数）
	 */
	private BigDecimal consigneeLng;
	/**
	 * 收货人地图纬度（保留地图所有小数）
	 */
	private BigDecimal consigneeLat;
	/**
	 * 收货人电话
	 */
	private String consigneeName;
	/**
	 * 收货人省份
	 */
	private String consigneePhone;
	/**
	 * 预约时间（24小时制：yyyy-MM-dd HH:mm:ss）
	 * 有效值：当前时间1-72小时内
	 */
	private String pickupTime;
	/**
	 * 指派自由人接单（自由人注册时的电话号码，多个自由人以逗号分隔，最多可以设置20个名额）
	 * 系统将优先推送给指定的自由人，如果超过一定时间后无人接单，才推送给所有自由人.
	 * TODO 生成订单的时候可传入此参数
	 */
	private String dispatchers;
	/**
	 * 重要说明
	 */
	private String remark;
	/**
	 * 回调地址
	 */
	private String callbackUrl;
	
	private String orderNo;
	
	private String reason;
	
	public String getUserName() {
		return userName;
	}
	public void setUserName(String userName) {
		this.userName = userName;
	}
	public Integer getGoodsWeight() {
		return goodsWeight;
	}
	public void setGoodsWeight(Integer goodsWeight) {
		this.goodsWeight = goodsWeight;
	}
	public Integer getGoodsWorth() {
		return goodsWorth;
	}
	public void setGoodsWorth(Integer goodsWorth) {
		this.goodsWorth = goodsWorth;
	}
	public Integer getMapFrom() {
		return mapFrom;
	}
	public void setMapFrom(Integer mapFrom) {
		this.mapFrom = mapFrom;
	}
	public String getStartingPhone() {
		return startingPhone;
	}
	public void setStartingPhone(String startingPhone) {
		this.startingPhone = startingPhone;
	}
	public String getStartingProvince() {
		return startingProvince;
	}
	public void setStartingProvince(String startingProvince) {
		this.startingProvince = startingProvince;
	}
	public String getStartingCity() {
		return startingCity;
	}
	public void setStartingCity(String startingCity) {
		this.startingCity = startingCity;
	}
	public String getStartingAddress() {
		return startingAddress;
	}
	public void setStartingAddress(String startingAddress) {
		this.startingAddress = startingAddress;
	}
	public BigDecimal getStartingLng() {
		return startingLng;
	}
	public void setStartingLng(BigDecimal startingLng) {
		this.startingLng = startingLng;
	}
	public BigDecimal getStartingLat() {
		return startingLat;
	}
	public void setStartingLat(BigDecimal startingLat) {
		this.startingLat = startingLat;
	}
	public String getConsigneeProvince() {
		return consigneeProvince;
	}
	public void setConsigneeProvince(String consigneeProvince) {
		this.consigneeProvince = consigneeProvince;
	}
	public String getConsigneeCity() {
		return consigneeCity;
	}
	public void setConsigneeCity(String consigneeCity) {
		this.consigneeCity = consigneeCity;
	}
	public String getConsigneeAddress() {
		return consigneeAddress;
	}
	public void setConsigneeAddress(String consigneeAddress) {
		this.consigneeAddress = consigneeAddress;
	}
	public BigDecimal getConsigneeLng() {
		return consigneeLng;
	}
	public void setConsigneeLng(BigDecimal consigneeLng) {
		this.consigneeLng = consigneeLng;
	}
	public BigDecimal getConsigneeLat() {
		return consigneeLat;
	}
	public void setConsigneeLat(BigDecimal consigneeLat) {
		this.consigneeLat = consigneeLat;
	}
	public String getPickupTime() {
		return pickupTime;
	}
	public void setPickupTime(String pickupTime) {
		this.pickupTime = pickupTime;
	}
	public String getDispatchers() {
		return dispatchers;
	}
	public void setDispatchers(String dispatchers) {
		this.dispatchers = dispatchers;
	}
	public String getRemark() {
		return remark;
	}
	public void setRemark(String remark) {
		this.remark = remark;
	}
	public String getCallbackUrl() {
		return callbackUrl;
	}
	public void setCallbackUrl(String callbackUrl) {
		this.callbackUrl = callbackUrl;
	}
	public String getBusinessNo() {
		return businessNo;
	}
	public void setBusinessNo(String businessNo) {
		this.businessNo = businessNo;
	}
	public String getGoodsName() {
		return goodsName;
	}
	public void setGoodsName(String goodsName) {
		this.goodsName = goodsName;
	}
	public String getConsigneeName() {
		return consigneeName;
	}
	public void setConsigneeName(String consigneeName) {
		this.consigneeName = consigneeName;
	}
	public String getConsigneePhone() {
		return consigneePhone;
	}
	public void setConsigneePhone(String consigneePhone) {
		this.consigneePhone = consigneePhone;
	}
	public String getStartingName() {
		return startingName;
	}
	public void setStartingName(String startingName) {
		this.startingName = startingName;
	}
	public String getOrderNo() {
	return orderNo;
	}
	public void setOrderNo(String orderNo) {
	this.orderNo = orderNo;
	}
	public String getReason() {
	return reason;
	}
	public void setReason(String reason) {
	this.reason = reason;
	}

}
