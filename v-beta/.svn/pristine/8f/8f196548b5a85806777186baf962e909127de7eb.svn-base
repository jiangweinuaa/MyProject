package com.dsc.spos.waimai.dianwoda;

public class DianwodaMessage {

	/**
	 * 消息类型(点我达在URL参数里面，为了方便添加到这里面)：
	 * dianwoda.order.status-update=订单状态变更[消息];
	 */
	private String type;
	
	private String msg_id;

  private Long pub_time;

  private Integer deliver_times;

  private String content;

	public String getMsg_id() {
		return msg_id;
	}

	public void setMsg_id(String msg_id) {
		this.msg_id = msg_id;
	}

	public Long getPub_time() {
		return pub_time;
	}

	public void setPub_time(Long pub_time) {
		this.pub_time = pub_time;
	}

	public Integer getDeliver_times() {
		return deliver_times;
	}

	public void setDeliver_times(Integer deliver_times) {
		this.deliver_times = deliver_times;
	}

	public String getContent() {
		return content;
	}

	public void setContent(String content) {
		this.content = content;
	}

	public String getType() {
		return type;
	}

	public void setType(String type) {
		this.type = type;
	}
  
  
}
