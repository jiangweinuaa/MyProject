import com.dsc.spos.json.cust.JsonRes;

/**
 * 
 * @author Huawei
 *
 */
public class DCP_StockChannelOrderQueryRes extends JsonRes {
	
	private levelRes datas;
	
	public levelRes getDatas() {
		return datas;
	}

	public void setDatas(levelRes datas) {
		this.datas = datas;
	}

	public class levelRes{

		private List<BillList> billList;

		public List<BillList> getBillList() {
			return billList;
		}

		public void setBillList(List<BillList> billList) {
			this.billList = billList;
		}
	}
	
	
	public class BillList{
		
		private String billNo;
		private String channelId;
		private String channelName;
		private String totAmt;
		private String totCQty;
		private String totPQty;
		private String createOpId;
		private String createOpName;
		private String createTime;
		private String memo;
		private String dealType;
		
		public String getDealType() {
			return dealType;
		}
		public void setDealType(String dealType) {
			this.dealType = dealType;
		}
		public String getBillNo() {
			return billNo;
		}
		public String getChannelId() {
			return channelId;
		}
		public String getChannelName() {
			return channelName;
		}
		public String getTotAmt() {
			return totAmt;
		}
		public String getTotCQty() {
			return totCQty;
		}
		public String getTotPQty() {
			return totPQty;
		}
		public String getCreateOpId() {
			return createOpId;
		}
		public String getCreateOpName() {
			return createOpName;
		}
		public String getCreateTime() {
			return createTime;
		}
		public String getMemo() {
			return memo;
		}
		public void setBillNo(String billNo) {
			this.billNo = billNo;
		}
		public void setChannelId(String channelId) {
			this.channelId = channelId;
		}
		public void setChannelName(String channelName) {
			this.channelName = channelName;
		}
		public void setTotAmt(String totAmt) {
			this.totAmt = totAmt;
		}
		public void setTotCQty(String totCQty) {
			this.totCQty = totCQty;
		}
		public void setTotPQty(String totPQty) {
			this.totPQty = totPQty;
		}
		public void setCreateOpId(String createOpId) {
			this.createOpId = createOpId;
		}
		public void setCreateOpName(String createOpName) {
			this.createOpName = createOpName;
		}
		public void setCreateTime(String createTime) {
			this.createTime = createTime;
		}
		public void setMemo(String memo) {
			this.memo = memo;
		}
		
	}
	
	
