package com.dsc.spos.thirdpart.youzan.request;

/**
 * 接收有赞 消息推送(基础) 原2.0基础模板
 * @author LN 08546
 */
public class YouZanNotifyBasicReq {

	public YouZanNotifyBasicReq() {
		
	}

	/**
	 * 消息业务类型
	 * 1.trade_TradePaid 交易支付消息，当一笔支付成功推送此消息。注意：此消息不具备发待货条件！该消息仅表示订单已支付，并不代表订单待发货
	 */
	private String type;//
	private String test;//false-非测试消息，true-测试消息
	private String msg;//经过UrlEncode(UTF-8)编码,需要解码
	private String status;//
	private String kdt_id;//店铺编号
	private String kdt_name;//店铺名称
	public String getType() {
		return type;
	}
	public void setType(String type) {
		this.type = type;
	}
	public String getTest() {
		return test;
	}
	public void setTest(String test) {
		this.test = test;
	}
	public String getMsg() {
		return msg;
	}
	public void setMsg(String msg) {
		this.msg = msg;
	}
	public String getStatus() {
		return status;
	}
	public void setStatus(String status) {
		this.status = status;
	}
	public String getKdt_id() {
		return kdt_id;
	}
	public void setKdt_id(String kdt_id) {
		this.kdt_id = kdt_id;
	}
	public String getKdt_name() {
		return kdt_name;
	}
	public void setKdt_name(String kdt_name) {
		this.kdt_name = kdt_name;
	}
	


	

}
