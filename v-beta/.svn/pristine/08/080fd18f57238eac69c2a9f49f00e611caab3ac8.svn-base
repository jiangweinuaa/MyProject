package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 大物流中心资料新增
 * @author yuanyy 2019-03-27
 *
 */
public class DCP_OrderECDCCreateReq extends JsonBasicReq {

	private String dcNo;
	private String dcName;
	private String lgPlatformNo;
	private String lgPlatformName;
	private String dcContactman;
	private String dcPhone;
	private String dcAddress;
	private String status;

	public String getDcNo() {
		return dcNo;
	}
	public void setDcNo(String dcNo) {
		this.dcNo = dcNo;
	}
	public String getDcName() {
		return dcName;
	}
	public void setDcName(String dcName) {
		this.dcName = dcName;
	}
	public String getLgPlatformNo() {
		return lgPlatformNo;
	}
	public void setLgPlatformNo(String lgPlatformNo) {
		this.lgPlatformNo = lgPlatformNo;
	}
	public String getLgPlatformName() {
		return lgPlatformName;
	}
	public void setLgPlatformName(String lgPlatformName) {
		this.lgPlatformName = lgPlatformName;
	}
	public String getDcContactman() {
		return dcContactman;
	}
	public void setDcContactman(String dcContactman) {
		this.dcContactman = dcContactman;
	}
	public String getDcPhone() {
		return dcPhone;
	}
	public void setDcPhone(String dcPhone) {
		this.dcPhone = dcPhone;
	}
	public String getDcAddress() {
		return dcAddress;
	}
	public void setDcAddress(String dcAddress) {
		this.dcAddress = dcAddress;
	}
	public String getStatus() {
		return status;
	}
	public void setStatus(String status) {
		this.status = status;
	}



}
