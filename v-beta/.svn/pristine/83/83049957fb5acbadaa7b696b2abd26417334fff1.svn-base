package com.dsc.spos.json.cust.req;

import java.util.List;

import com.dsc.spos.json.cust.JsonReq;
import com.dsc.spos.json.cust.req.DCP_LStockOutCreateReq.levelElm;

/**
 * JOB 执行时间设置 
 * 设置JOB 执行时间点， 如 12：00：00 ， 20：00：00
 * 不同于轮询时间
 * @author yuanyy 2019-06-24 
 *
 */
public class DCP_JobDetailSetQueryReq extends JsonReq {

	private levelElm request;
	public levelElm getRequest() {
		return request;
	}
	public void setRequest(levelElm request) {
		this.request = request;
	}
	public class levelElm{
		private String jobName ;
		public String getJobName() {
			return jobName;
		}
		public void setJobName(String jobName) {
			this.jobName = jobName;
		}

	}



}
