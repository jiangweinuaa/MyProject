package com.dsc.spos.hll.api.response;

/**
 * 营销活动详情
 * @author LN 08546
 */
public class HllPromotionDetail {
	
	
	/**
	 * 记录ID
	 */
	private String itemID;
	
	/**
	 * 报表统计日期，门店增加数据清机结转时间设定，该时间为次日小时数（1~12），默认为1，即次日凌晨1点。根据业态的不同，可以选择不同的时间。例如落单和结账的时候，根据收市时间设定，更新该字段为逻辑日期
	 */
	private String reportDate;
	
	/**
	 * 所属集团ID
	 */
	private String groupID;
	
	/**
	 * 店铺ID
	 */
	private String shopID;
	
	/**
	 * 餐饮系统订单Key
	 */
	private String saasOrderKey;
	
	/**
	 * 订单状态 30: 作废 40：已结账
	 */
	private String orderStatus;
		
	/**
	 * food表明细记录Key
	 */
	private String itemKey;
	
	/**
	 * 店铺名称
	 */
	private String shopName;
	
	/**
	 * 促销唯一标识
	 */
	private String promotionID;
	
	/**
	 * 促销统计类别
	 */
	private String promotionCategoryname;
	
	/**
	 * 促销类型
	 */
	private String promotionType;
	
	/**
	 * 促销编码
	 */
	private String promotionCode;
	
	/**
	 * 促销名称
	 */
	private String promotionName;
	
	/**
	 * 促销标签
	 */
	private String promotionTagLst;
	
	/**
	 * 菜品名称
	 */
	private String foodName;
	
	/**
	 * 菜品规格Key 目前对应的是规格ID
	 */
	private String unitKey;
	
	/**
	 * 点菜数量
	 */
	private String foodCount;
	
	/**
	 * 备注是否为赠菜，0：否，1：是
	 */
	private String isPromotionGift;
	
	/**
	 * 菜品优惠金额
	 */
	private String deltaPromotionAmount;

	public String getItemID() {
		return itemID;
	}

	public void setItemID(String itemID) {
		this.itemID = itemID;
	}

	public String getReportDate() {
		return reportDate;
	}

	public void setReportDate(String reportDate) {
		this.reportDate = reportDate;
	}

	public String getGroupID() {
		return groupID;
	}

	public void setGroupID(String groupID) {
		this.groupID = groupID;
	}

	public String getShopID() {
		return shopID;
	}

	public void setShopID(String shopID) {
		this.shopID = shopID;
	}

	public String getSaasOrderKey() {
		return saasOrderKey;
	}

	public void setSaasOrderKey(String saasOrderKey) {
		this.saasOrderKey = saasOrderKey;
	}

	public String getOrderStatus() {
		return orderStatus;
	}

	public void setOrderStatus(String orderStatus) {
		this.orderStatus = orderStatus;
	}

	public String getItemKey() {
		return itemKey;
	}

	public void setItemKey(String itemKey) {
		this.itemKey = itemKey;
	}

	public String getShopName() {
		return shopName;
	}

	public void setShopName(String shopName) {
		this.shopName = shopName;
	}

	public String getPromotionID() {
		return promotionID;
	}

	public void setPromotionID(String promotionID) {
		this.promotionID = promotionID;
	}

	public String getPromotionCategoryname() {
		return promotionCategoryname;
	}

	public void setPromotionCategoryname(String promotionCategoryname) {
		this.promotionCategoryname = promotionCategoryname;
	}

	public String getPromotionType() {
		return promotionType;
	}

	public void setPromotionType(String promotionType) {
		this.promotionType = promotionType;
	}

	public String getPromotionCode() {
		return promotionCode;
	}

	public void setPromotionCode(String promotionCode) {
		this.promotionCode = promotionCode;
	}

	public String getPromotionName() {
		return promotionName;
	}

	public void setPromotionName(String promotionName) {
		this.promotionName = promotionName;
	}

	public String getPromotionTagLst() {
		return promotionTagLst;
	}

	public void setPromotionTagLst(String promotionTagLst) {
		this.promotionTagLst = promotionTagLst;
	}

	public String getFoodName() {
		return foodName;
	}

	public void setFoodName(String foodName) {
		this.foodName = foodName;
	}

	public String getUnitKey() {
		return unitKey;
	}

	public void setUnitKey(String unitKey) {
		this.unitKey = unitKey;
	}

	public String getFoodCount() {
		return foodCount;
	}

	public void setFoodCount(String foodCount) {
		this.foodCount = foodCount;
	}

	public String getIsPromotionGift() {
		return isPromotionGift;
	}

	public void setIsPromotionGift(String isPromotionGift) {
		this.isPromotionGift = isPromotionGift;
	}

	public String getDeltaPromotionAmount() {
		return deltaPromotionAmount;
	}

	public void setDeltaPromotionAmount(String deltaPromotionAmount) {
		this.deltaPromotionAmount = deltaPromotionAmount;
	}
	

}
