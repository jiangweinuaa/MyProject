package com.dsc.spos.json.cust.req;

import java.util.List;

import com.dsc.spos.json.JsonBasicReq;

public class DCP_FlavorCreateReq extends JsonBasicReq
{	
	private levelRequest request;

	public levelRequest getRequest() {
		return request;
	}

	public void setRequest(levelRequest request) {
		this.request = request;
	}

	public class levelRequest
	{
		private String flavorId ;//
		private List<levelFlavor> flavorName_lang ;//
		private String groupId ;//
		private String sortId ;//
		public String getFlavorId() {
			return flavorId;
		}
		public void setFlavorId(String flavorId) {
			this.flavorId = flavorId;
		}
		
		public List<levelFlavor> getFlavorName_lang() {
			return flavorName_lang;
		}
		public void setFlavorName_lang(List<levelFlavor> flavorName_lang) {
			this.flavorName_lang = flavorName_lang;
		}
		public String getGroupId() {
			return groupId;
		}
		public void setGroupId(String groupId) {
			this.groupId = groupId;
		}
		public String getSortId() {
			return sortId;
		}
		public void setSortId(String sortId) {
			this.sortId = sortId;
		}
		
		
	}
	
	public class levelFlavor
	{
		private String langType ;//
		private String name ;//
		public String getLangType() {
			return langType;
		}
		public void setLangType(String langType) {
			this.langType = langType;
		}
		public String getName() {
			return name;
		}
		public void setName(String name) {
			this.name = name;
		}		
	}
		
	
}
