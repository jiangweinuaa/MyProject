package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

public class DCP_MachShopQueryReq extends JsonBasicReq
{
	private levelReq request;

	public levelReq getRequest()
	{
		return request;
	}

	public void setRequest(levelReq request)
	{
		this.request = request;
	}

	public class levelReq
	{

		private String eId;
		private String shippingShopNo;
		public String geteId()
		{
			return eId;
		}
		public void seteId(String eId)
		{
			this.eId = eId;
		}
		public String getShippingShopNo()
		{
			return shippingShopNo;
		}
		public void setShippingShopNo(String shippingShopNo)
		{
			this.shippingShopNo = shippingShopNo;
		}
		
	}
}
