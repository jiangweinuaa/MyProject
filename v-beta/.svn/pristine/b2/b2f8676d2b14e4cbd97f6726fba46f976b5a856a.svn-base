package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 订单同意处理
 * @author yuanyy
 *
 */
public class DCP_OrderAgreeProcessReq extends JsonBasicReq {

	private String oEId;
	private String oShopId;
	private String o_opNO;
	private String[] docType;	
	private String orderNO;
	private String getType;
	private String reasonCode;//退单原因  不传默认0-未知、1-未付款自主取消、2-超时未支付、3-商家拒单、4-用户申请退单
	private String reason;//退单原因描述 
	public String getoEId() {
		return oEId;
	}
	public void setoEId(String oEId) {
		this.oEId = oEId;
	}

	public String getoShopId() {
		return oShopId;
	}
	public void setoShopId(String oShopId) {
		this.oShopId = oShopId;
	}
	public String getO_opNO() {
		return o_opNO;
	}
	public void setO_opNO(String o_opNO) {
		this.o_opNO = o_opNO;
	}
	public String[] getDocType() {
		return docType;
	}
	public void setDocType(String[] docType) {
		this.docType = docType;
	}
	public String getOrderNO() {
		return orderNO;
	}
	public void setOrderNO(String orderNO) {
		this.orderNO = orderNO;
	}
	public String getGetType() {
		return getType;
	}
	public void setGetType(String getType) {
		this.getType = getType;
	}
	public String getReasonCode() {
		return reasonCode;
	}
	public void setReasonCode(String reasonCode) {
		this.reasonCode = reasonCode;
	}
	public String getReason() {
		return reason;
	}
	public void setReason(String reason) {
		this.reason = reason;
	}




}
