package com.dsc.spos.json.cust.res;

import java.util.List;
import java.util.Map;
import com.dsc.spos.json.JsonBasicRes;

/**
 * DayEndCheckRes 專用的 response json
 * @author cehnsong 
 * @since  2016-11-22
 */

public class DCP_DayEndCheckRes extends JsonBasicRes {
	private List<level2Elm> dayEndCheckDatas;

	public List<level2Elm> getDayEndCheckDatas() {
		return dayEndCheckDatas;
	}

	public void setDayEndCheckDatas(List<level2Elm> dayEndCheckDatas) {
		this.dayEndCheckDatas = dayEndCheckDatas;
	}

	public class level2Elm
	{

		private String shopId;
    	private String status;
    	private String code;
    	private String description;
    	
		public String getCode() {
			return code;
		}
		public void setCode(String code) {
			this.code = code;
		}
		public String getShopId() {
			return shopId;
		}
		public void setShopId(String shopId) {
			this.shopId = shopId;
		}
		public String getStatus() {
			return status;
		}
		public void setStatus(String status) {
			this.status = status;
		}
		public String getDescription() {
			return description;
		}
		public void setDescription(String description) {
			this.description = description;
		}

	}
}