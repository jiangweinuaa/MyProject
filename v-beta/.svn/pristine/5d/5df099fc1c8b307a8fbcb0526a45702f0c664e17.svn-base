package com.dsc.spos.json.cust.res;

import java.util.List;

import com.dsc.spos.json.cust.JsonRes;

/**
 * 服务地址查询：扫码点餐专用， 这服务完全没用,胡扯。 有问题找王欢
 *
 */
public class DCP_ServiceAddressQuery_OpenRes extends JsonRes {
	private List<level1Elm> datas;
	
	public List<level1Elm> getDatas() {
		return datas;
	}

	public void setDatas(List<level1Elm> datas) {
		this.datas = datas;
	}


	public class level1Elm{
		
		private String dcpService; //DCP中台服务地址	
		private String posService; //POS服务地址	
		private String crmService; //CRM会员服务地址	
		private String payService; //PAY支付服务地址	
		private String promService;//PROM服务地址	
		private String pictureGetAddress;//图片服务外网地址	
		
		public String getDcpService() {
			return dcpService;
		}
		public String getPosService() {
			return posService;
		}
		public String getCrmService() {
			return crmService;
		}
		public String getPayService() {
			return payService;
		}
		public String getPromService() {
			return promService;
		}
		public String getPictureGetAddress() {
			return pictureGetAddress;
		}
		public void setDcpService(String dcpService) {
			this.dcpService = dcpService;
		}
		public void setPosService(String posService) {
			this.posService = posService;
		}
		public void setCrmService(String crmService) {
			this.crmService = crmService;
		}
		public void setPayService(String payService) {
			this.payService = payService;
		}
		public void setPromService(String promService) {
			this.promService = promService;
		}
		public void setPictureGetAddress(String pictureGetAddress) {
			this.pictureGetAddress = pictureGetAddress;
		}
		
		
		
	}
}
