package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

public class DCP_CRegisterCheckReq extends JsonBasicReq
{
	private levelElm request;
	public levelElm getRequest() {
		return request;
	}
	public void setRequest(levelElm request) {
		this.request = request;
	}
	public class levelElm{
		private String machineName;
		private String motherBoardSn;
		private String hardDiskSn;
		private String cpuSerial;
		private String smac;
		private String installpath;
		private String machincode;
		private String producttype;
		private String rEId;
		private String rShopId;
		private String rmachine;


		public String getrEId() {
			return rEId;
		}
		public void setrEId(String rEId) {
			this.rEId = rEId;
		}
		public String getRmachine() {
			return rmachine;
		}
		public String getrShopId() {
			return rShopId;
		}
		public void setrShopId(String rShopId) {
			this.rShopId = rShopId;
		}
		public void setRmachine(String rmachine) {
			this.rmachine = rmachine;
		}
		public String getMachineName() {
			return machineName;
		}
		public void setMachineName(String machineName) {
			this.machineName = machineName;
		}
		public String getMotherBoardSn() {
			return motherBoardSn;
		}
		public void setMotherBoardSn(String motherBoardSn) {
			this.motherBoardSn = motherBoardSn;
		}
		public String getHardDiskSn() {
			return hardDiskSn;
		}
		public void setHardDiskSn(String hardDiskSn) {
			this.hardDiskSn = hardDiskSn;
		}
		public String getCpuSerial() {
			return cpuSerial;
		}
		public void setCpuSerial(String cpuSerial) {
			this.cpuSerial = cpuSerial;
		}
		public String getSmac() {
			return smac;
		}
		public void setSmac(String smac) {
			this.smac = smac;
		}
		public String getInstallpath() {
			return installpath;
		}
		public void setInstallpath(String installpath) {
			this.installpath = installpath;
		}
		public String getMachincode() {
			return machincode;
		}
		public void setMachincode(String machincode) {
			this.machincode = machincode;
		}
		public String getProducttype() {
			return producttype;
		}
		public void setProducttype(String producttype) {
			this.producttype = producttype;
		}
	}

}


