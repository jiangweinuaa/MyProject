package com.dsc.spos.json.cust.res;

import java.util.List;

import com.dsc.spos.json.cust.JsonRes;

public class DCP_OrderListQueryRes extends JsonRes
{
	private List<level1Elm> datas;
	
	public class level1Elm
	{
		private String proName;
		private String qty;
		private String status;
		private String min_Rdate;
		private String max_Rdate;
		private String delstatus;
		
	public String getProName() {
		return proName;
	}
	public void setProName(String proName) {
		this.proName = proName;
	}
	public String getQty() {
		return qty;
	}
	public void setQty(String qty) {
		this.qty = qty;
	}
	public String getStatus() {
		return status;
	}
	public void setStatus(String status) {
		this.status = status;
	}
	public String getMin_Rdate() {
		return min_Rdate;
	}
	public void setMin_Rdate(String min_Rdate) {
		this.min_Rdate = min_Rdate;
	}
	public String getMax_Rdate() {
		return max_Rdate;
	}
	public void setMax_Rdate(String max_Rdate) {
		this.max_Rdate = max_Rdate;
	}
	public String getDelstatus() {
	return delstatus;
	}
	public void setDelstatus(String delstatus) {
	this.delstatus = delstatus;
	}
		
	}

	public List<level1Elm> getDatas() {
	return datas;
	}

	public void setDatas(List<level1Elm> datas) {
	this.datas = datas;
	}
	
	
}
