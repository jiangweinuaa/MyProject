package com.dsc.spos.json.cust.res;

import java.util.List;

import com.dsc.spos.json.cust.JsonRes;

public class DCP_RegeisterModuleInfoQueryRes extends JsonRes
{
	private List<level1Elm> datas;
	public class level1Elm
	{
		private String rModularNo;
		private String rModularName;
		private List<level2Elm> datas_Func;
		public String getrModularNo() {
			return rModularNo;
		}
		public void setrModularNo(String rModularNo) {
			this.rModularNo = rModularNo;
		}
		public String getrModularName() {
			return rModularName;
		}
		public void setrModularName(String rModularName) {
			this.rModularName = rModularName;
		}
		public List<level2Elm> getDatas_Func() {
			return datas_Func;
		}
		public void setDatas_Func(List<level2Elm> datas_Func) {
			this.datas_Func = datas_Func;
		}
		
	}
	
	public class level2Elm
	{
		private String rFuncNo;
		private String rFuncName;
		private String rTypeInfo;
		private String rFuncInfo;
		
		public String getrFuncNo() {
			return rFuncNo;
		}
		public void setrFuncNo(String rFuncNo) {
			this.rFuncNo = rFuncNo;
		}
		public String getrFuncName() {
			return rFuncName;
		}
		public void setrFuncName(String rFuncName) {
			this.rFuncName = rFuncName;
		}
		public String getrTypeInfo() {
			return rTypeInfo;
		}
		public void setrTypeInfo(String rTypeInfo) {
			this.rTypeInfo = rTypeInfo;
		}
		public String getrFuncInfo() {
			return rFuncInfo;
		}
		public void setrFuncInfo(String rFuncInfo) {
			this.rFuncInfo = rFuncInfo;
		}
		
	}

	public List<level1Elm> getDatas() {
		return datas;
	}

	public void setDatas(List<level1Elm> datas) {
		this.datas = datas;
	}
}

