package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 电商订单Excel导出查询
 * @author yuanyy 2019-03-19
 *
 */
public class DCP_OrderECExpShippingQueryReq extends JsonBasicReq {
	
	private String ecPlatformNo;
	private String expOrderFormatNo;
	private String exportDoc;
	
	public String getEcPlatformNo() {
		return ecPlatformNo;
	}
	public void setEcPlatformNo(String ecPlatformNo) {
		this.ecPlatformNo = ecPlatformNo;
	}
	public String getExpOrderFormatNo() {
		return expOrderFormatNo;
	}
	public void setExpOrderFormatNo(String expOrderFormatNo) {
		this.expOrderFormatNo = expOrderFormatNo;
	}
	public String getExportDoc() {
		return exportDoc;
	}
	public void setExportDoc(String exportDoc) {
		this.exportDoc = exportDoc;
	}
	
}
