package com.dsc.spos.json.cust.req;

import java.util.List;
import java.util.Map;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 服務函數：StockTaskCreateDCPReq
 *   說明：收货通知单新增
 * 服务说明：收货通知单新增
 * @author chensong
 * @since  2016-10-12
 */
public class DCP_StockTaskCreateReq extends JsonBasicReq{
	private String remark;
	private String loadDocType;
	private String loadDocNO;
	private String Bdate;
	private String docType;	
	private String btake;
	private String taskWay;
	private String notgoodsMode ;	
	private String operation_type;
	private String isAdjustStock;
	
	private List<Map<String, String>> stocktaskshop;
	private List<Map<String, String>> stocktaskrange;
	private List<Map<String, String>> stocktasklist;
	public String getRemark() {
		return remark;
	}
	public void setRemark(String remark) {
		this.remark = remark;
	}
	public String getLoadDocType() {
		return loadDocType;
	}
	public void setLoadDocType(String loadDocType) {
		this.loadDocType = loadDocType;
	}
	public String getLoadDocNO() {
		return loadDocNO;
	}
	public void setLoadDocNO(String loadDocNO) {
		this.loadDocNO = loadDocNO;
	}
	public String getBdate() {
		return Bdate;
	}
	public void setBdate(String bdate) {
		Bdate = bdate;
	}
	public String getDocType() {
		return docType;
	}
	public void setDocType(String docType) {
		this.docType = docType;
	}
	public List<Map<String, String>> getStocktaskshop() {
		return stocktaskshop;
	}
	public void setStocktaskshop(List<Map<String, String>> stocktaskshop) {
		this.stocktaskshop = stocktaskshop;
	}
	public List<Map<String, String>> getStocktaskrange() {
		return stocktaskrange;
	}
	public void setStocktaskrange(List<Map<String, String>> stocktaskrange) {
		this.stocktaskrange = stocktaskrange;
	}
	public List<Map<String, String>> getStocktasklist() {
		return stocktasklist;
	}
	public void setStocktasklist(List<Map<String, String>> stocktasklist) {
		this.stocktasklist = stocktasklist;
	}
	public String getBtake() {
	return btake;
	}
	public void setBtake(String btake) {
	this.btake = btake;
	}
	public String getTaskWay() {
	return taskWay;
	}
	public void setTaskWay(String taskWay) {
	this.taskWay = taskWay;
	}
	public String getNotgoodsMode() {
	return notgoodsMode;
	}
	public void setNotgoodsMode(String notgoodsMode) {
	this.notgoodsMode = notgoodsMode;
	}
	public String getOperation_type() {
	return operation_type;
	}
	public void setOperation_type(String operation_type) {
	this.operation_type = operation_type;
	}
	public String getIsAdjustStock() {
		return isAdjustStock;
	}
	public void setIsAdjustStock(String isAdjustStock) {
		this.isAdjustStock = isAdjustStock;
	}	


}
