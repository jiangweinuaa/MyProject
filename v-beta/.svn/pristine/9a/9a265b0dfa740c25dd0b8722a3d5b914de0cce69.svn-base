import com.dsc.spos.json.cust.req.DCP_ParaTemplateRetrieveReq.level1Elm;

public class DCP_ParaSetQueryNewReq extends JsonBasicReq {
	
	private level1Elm request;

	public level1Elm getRequest() {
		return request;
	}

	public void setRequest(level1Elm request) {
		this.request = request;
	}

	public class level1Elm{
		private String paraShop;
		private String paraMachine;

		private String keyTxt;
		private String modularId;
		public String getParaShop() {
			return paraShop;
		}
		public String getParaMachine() {
			return paraMachine;
		}
		public String getKeyTxt() {
