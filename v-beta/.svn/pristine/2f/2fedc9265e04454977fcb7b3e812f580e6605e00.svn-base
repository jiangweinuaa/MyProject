package com.dsc.spos.json.cust.req;

import java.util.List;
import com.dsc.spos.json.JsonBasicReq;

public class DCP_OrderMappingCategoryCreateReq extends JsonBasicReq 
{
	private String shopId;
	private String orderType;
	private List<level1Elm> datas;

	public String getShopId() {
		return shopId;
	}
	public void setShopId(String shopId) {
		this.shopId = shopId;
	}
	public String getOrderType() {
		return orderType;
	}
	public void setOrderType(String orderType) {
		this.orderType = orderType;
	}
	public List<level1Elm> getDatas() {
		return datas;
	}
	public void setDatas(List<level1Elm> datas) {
		this.datas = datas;
	}

	public  class level1Elm
	{
		private String category;
		private String orderCategory;
		private String categoryName;
		private String orderCategoryName;
		public String getCategory() {
			return category;
		}
		public void setCategory(String category) {
			this.category = category;
		}
		public String getOrderCategory() {
			return orderCategory;
		}
		public void setOrderCategory(String orderCategory) {
			this.orderCategory = orderCategory;
		}
		public String getCategoryName() {
			return categoryName;
		}
		public void setCategoryName(String categoryName) {
			this.categoryName = categoryName;
		}
		public String getOrderCategoryName() {
			return orderCategoryName;
		}
		public void setOrderCategoryName(String orderCategoryName) {
			this.orderCategoryName = orderCategoryName;
		}

	}

}
