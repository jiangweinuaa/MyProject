package com.dsc.spos.json.cust.req;

import com.dsc.spos.json.JsonBasicReq;

/**
 * 电商出货单查询
 * @author yuanyy 2019-03-19
 *
 */
public class DCP_OrderECShippingQueryReq extends JsonBasicReq {
	/**
	 * {	
	   "serviceId": "OrderECShippingGetDCP",	必传，服务名
	   "token": "f14ee75ff5b220177ac0dc538bdea08c",	必传且非空，访问令牌
	    "lgPlatformNo": ""	必传且非空，货运厂商代码
	    "ecPlatformNo": ""	电商平台代码
	    "expressBilltype": ""	托运单类别  A:一般托运单 B:代收托运单
	    "expressNo": ""	托运单号
	    "temperateLayerNo": ""	1.常溫 2.冷藏 3.冷凍
	    "shipmentNo": "",	出货单号
	    "createBy": ["123","456"],	点货人员代号
	    "startDate": "",	货运单开始日期
	    "endDate": "",	货运单结束日期
	    "printStatus": "",	列印状态  1:未列印 2:已列印  
	    "shipStatus":"1",
	    "ecOrderNo":""
		}	
	 */
	
	private String lgPlatformNo;
	private String ecPlatformNo;
	private String expressBilltype;
	private String expressNo;
	private String temperateLayerNo;
	private String shipmentNo;
	private String[] createBy;
	private String startDate;
	private String endDate;
	private String printStatus;
	private String shipStatus;
	private String ecOrderNo;
	private String telphone;
	private String exportDoc;
	
	
	public String getLgPlatformNo() {
		return lgPlatformNo;
	}
	public void setLgPlatformNo(String lgPlatformNo) {
		this.lgPlatformNo = lgPlatformNo;
	}
	public String getEcPlatformNo() {
		return ecPlatformNo;
	}
	public void setEcPlatformNo(String ecPlatformNo) {
		this.ecPlatformNo = ecPlatformNo;
	}
	public String getExpressBilltype() {
		return expressBilltype;
	}
	public void setExpressBilltype(String expressBilltype) {
		this.expressBilltype = expressBilltype;
	}
	public String getExpressNo() {
		return expressNo;
	}
	public void setExpressNo(String expressNo) {
		this.expressNo = expressNo;
	}
	public String getTemperateLayerNo() {
		return temperateLayerNo;
	}
	public void setTemperateLayerNo(String temperateLayerNo) {
		this.temperateLayerNo = temperateLayerNo;
	}
	public String getShipmentNo() {
		return shipmentNo;
	}
	public void setShipmentNo(String shipmentNo) {
		this.shipmentNo = shipmentNo;
	}
	public String[] getCreateBy() {
		return createBy;
	}
	public void setCreateBy(String[] createBy) {
		this.createBy = createBy;
	}
	public String getStartDate() {
		return startDate;
	}
	public void setStartDate(String startDate) {
		this.startDate = startDate;
	}
	public String getEndDate() {
		return endDate;
	}
	public void setEndDate(String endDate) {
		this.endDate = endDate;
	}
	public String getPrintStatus() {
		return printStatus;
	}
	public void setPrintStatus(String printStatus) {
		this.printStatus = printStatus;
	}
	public String getShipStatus() {
		return shipStatus;
	}
	public void setShipStatus(String shipStatus) {
		this.shipStatus = shipStatus;
	}
	public String getEcOrderNo() {
		return ecOrderNo;
	}
	public void setEcOrderNo(String ecOrderNo) {
		this.ecOrderNo = ecOrderNo;
	}
	public String getTelphone() {
		return telphone;
	}
	public void setTelphone(String telphone) {
		this.telphone = telphone;
	}
	public String getExportDoc() {
		return exportDoc;
	}
	public void setExportDoc(String exportDoc) {
		this.exportDoc = exportDoc;
	}
	
	
}
