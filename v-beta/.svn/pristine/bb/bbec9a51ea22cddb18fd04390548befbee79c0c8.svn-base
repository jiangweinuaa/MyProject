	}
	public void setLeaveTime(String leaveTime) {
		this.leaveTime = leaveTime;
	}
	public String getTourGroupNO() {
		return tourGroupNO;
	}
	public void setTourGroupNO(String tourGroupNO) {
		this.tourGroupNO = tourGroupNO;
	}
	public String getAddress() {
