	}
	public void setMemo(String memo) {
		this.memo = memo;
	}
	public String getArrivalTime() {
		return arrivalTime;
	}
	public void setArrivalTime(String arrivalTime) {
		this.arrivalTime = arrivalTime;
	}
	public String getLeaveTime() {
