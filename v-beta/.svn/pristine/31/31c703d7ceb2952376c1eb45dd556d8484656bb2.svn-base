        private String taxName;
        private String taxRate;
        private String billPrice;
        private String direction;
        private String preTaxAmt;
        private String amt;
        private String demandOrg;
        private String demandOrgName;
        private String demandCorp;
        private String demandCorpName;
        private String supplyOrg;
        private String supplyOrgName;
        private String supplyCorp;
        private String supplyCorpName;
        private String distribuOrg;
        private String distribuOrgName;
        private String distribuCorp;
        private String distribuCorpName;
