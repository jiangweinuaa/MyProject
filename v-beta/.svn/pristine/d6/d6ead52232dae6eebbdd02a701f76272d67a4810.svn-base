package com.dsc.spos.json.cust.res;

import java.util.List;

import com.dsc.spos.json.cust.JsonRes;

public class DCP_AppQueryRes extends JsonRes
{
	private List<level1Elm> datas;
	
	
	public List<level1Elm> getDatas() {
		return datas;
	}
	public void setDatas(List<level1Elm> datas) {
		this.datas = datas;
	}


	public class level1Elm
	{
		private String appNo;//应用编号
		private String appName;//应用名称
		private String isThird;//
		private String isOnline;//
		private String dockFunction;//渠道对接功能（0会员，1订单）
		
		public String getAppNo() {
			return appNo;
		}
		public void setAppNo(String appNo) {
			this.appNo = appNo;
		}
		public String getAppName() {
			return appName;
		}
		public void setAppName(String appName) {
			this.appName = appName;
		}
		public String getIsThird()
		{
			return isThird;
		}
		public void setIsThird(String isThird)
		{
			this.isThird = isThird;
		}
		public String getIsOnline()
		{
			return isOnline;
		}
		public void setIsOnline(String isOnline)
		{
			this.isOnline = isOnline;
		}
		public String getDockFunction()
		{
			return dockFunction;
		}
		public void setDockFunction(String dockFunction)
		{
			this.dockFunction = dockFunction;
		}
		
		
		
	}
	

}
