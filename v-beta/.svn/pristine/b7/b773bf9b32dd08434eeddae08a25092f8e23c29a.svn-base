package com.dsc.spos.waimai.jddj;


public class OPriceInfo {

   private String stationNo;
   private int price;
   private String pin;
   private String venderId;
   private long skuId;
   private int vipPrice;
   private int promoteVipPrice;
   public void setStationNo(String stationNo) {
        this.stationNo = stationNo;
    }
    public String getStationNo() {
        return stationNo;
    }

   public void setPrice(int price) {
        this.price = price;
    }
    public int getPrice() {
        return price;
    }

   public void setPin(String pin) {
        this.pin = pin;
    }
    public String getPin() {
        return pin;
    }

   public void setVenderId(String venderId) {
        this.venderId = venderId;
    }
    public String getVenderId() {
        return venderId;
    }

   public void setSkuId(long skuId) {
        this.skuId = skuId;
    }
    public long getSkuId() {
        return skuId;
    }

   public void setVipPrice(int vipPrice) {
        this.vipPrice = vipPrice;
    }
    public int getVipPrice() {
        return vipPrice;
    }

   public void setPromoteVipPrice(int promoteVipPrice) {
        this.promoteVipPrice = promoteVipPrice;
    }
    public int getPromoteVipPrice() {
        return promoteVipPrice;
    }

}